{
	"$schema": "https://docs.fallow.tools/schema.json",

	"entry": [
		"bin/orch.ts",
		"src/daemon/orchd.ts",
		"extensions/*/index.ts",
		"packages/web/src/router.tsx"
	],

	"ignorePatterns": [
		"dist/**",
		".fallow/**",
		"packages/web/.tanstack/**"
	],

	"ignoreDependencies": ["@tanstack/react-db", "react"],

	"overrides": [
		{
			"files": [
				"packages/web/src/components/ui/**",
				"packages/web/src/routeTree.gen.ts",
				"packages/web/src/themes/**"
			],
			"rules": {
				"unused-files": "off",
				"unused-exports": "off",
				"unused-types": "off",
				"unused-enum-members": "off",
				"unused-class-members": "off",
				"unused-component-props": "off",
				"unrendered-components": "off"
			}
		}
	],

	"duplicates": {
		"mode": "semantic",
		"minTokens": 35,
		"minLines": 3,
		"ignore": [
			"test/**",
			"scripts/**",
			"bin/**",
			"packages/web/src/components/ui/**",
			"packages/web/src/routeTree.gen.ts",
			"packages/web/src/themes/**"
		]
	},

	"health": {
		"maxCyclomatic": 12,
		"ignore": [
			"test/**",
			"scripts/**",
			"bin/**",
			"packages/web/src/components/ui/**",
			"packages/web/src/routeTree.gen.ts",
			"packages/web/src/themes/**"
		]
	},

	"audit": {
		"gate": "all"
	}
}
