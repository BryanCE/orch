{
  "name": "orch",
  "version": "0.2.0",
  "description": "Fleet orchestration control plane for pi agents in herdr panes — orch CLI, pif headless dispatch, and the pi extensions that make every agent visible and steerable.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "herdr",
    "orchestration",
    "agents"
  ],
  "scripts": {
    "check": "oxlint . && bunx tsc --noEmit && fallow check",
    "build": "bun run build:ext && bun run build:bin",
    "build:ext": "bun build extensions/orchestrator-bridge.ts --target=node --format=esm --outfile dist/extensions/orchestrator-bridge.js",
    "build:bin": "bun build bin/orch.ts --target=node --format=esm --outfile dist/bin/orch.js && bun scripts/build-bin.ts",
    "prepublishOnly": "bun run build",
    "tc": "bunx tsc --noEmit",
    "lint": "oxlint .",
    "test": "bun test"
  },
  "license": "MIT",
  "author": "Bryan Edman",
  "type": "module",
  "bin": {
    "orch": "./dist/bin/orch.js",
    "pif": "./bin/pif"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "extensions/",
    "dist/",
    "skills/",
    "agents/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "fallow": "^3.4.2",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7"
  },
  "trustedDependencies": [
    "@google/genai",
    "protobufjs"
  ]
}
