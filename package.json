{
  "name": "orch",
  "version": "0.1.0",
  "description": "Fleet orchestration control plane for pi agents in herdr panes — orch CLI, pif headless dispatch, and the pi extensions that make every agent visible and steerable.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "herdr",
    "orchestration",
    "agents"
  ],
  "scripts": {
    "check": "oxlint . && bunx tsc --noEmit && fallow check",
    "check:bridge": "bun scripts/check-bridge.ts",
    "build": "bun run build:cli && bun run build:web",
    "build:cli": "bun run build:ext && bun run build:bin && bun run build:daemon",
    "build:ext": "bun build extensions/orchestrator-bridge.ts --target=node --format=esm --outfile dist/extensions/orchestrator-bridge.js",
    "build:bin": "bun build bin/orch.ts --target=node --format=esm --outfile dist/bin/orch.js && bun scripts/build-bin.ts",
    "build:daemon": "bun build src/daemon/orchd.ts --target=node --format=esm --outfile dist/daemon/orchd.js",
    "build:web": "cd packages/web && bun run build",
    "build:dev": "bun run build:cli && bun link && echo 'orch CLI linked from dist/ — run \\'orch setup\\' to pick and install integrations'",
    "prepublishOnly": "bun run build",
    "tc": "bunx tsc --noEmit",
    "lint": "oxlint .",
    "test": "bun test"
  },
  "license": "MIT",
  "author": "Bryan Edman",
  "type": "module",
  "bin": {
    "orch": "./dist/bin/orch.js",
    "pif": "./bin/pif"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "extensions/",
    "dist/",
    "skills/",
    "agents/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@tanstack/react-db": "^0.1.92",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typebox": "^1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@vitejs/plugin-react": "^6.0.3",
    "fallow": "^3.4.2",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^7",
    "vite": "^8.1.4"
  },
  "trustedDependencies": [
    "@google/genai",
    "protobufjs"
  ]
}
